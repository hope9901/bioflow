  #     given-names: Gildong
  - name: "hope9901"
    email: hope9901@gmail.com
repository-code: "https://github.com/hope9901/bioflow"
url: "https://hope9901.github.io/bioflow/"
license: MIT
version: "0.3.1"
date-released: "2026-06-29"
keywords:
  - bioinformatics
  - reproducibility
  - provenance
  - workflow
  - genomics
  - containers
  - biocontainers
